generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["medcare"]
}

model User {
  id           String  @id @default(cuid())
  mobile       String? @unique
  name         String?
  email        String? @unique
  passwordHash String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientMedicines   PatientMedicine[]
  medicineIntakes    MedicineIntake[]
  pushSubscriptions  PushSubscription[]
  notifications      Notification[]
  notificationPrefs  NotificationPreference?
  otpRequests        OTPRequest[]
  passwordResetTokens PasswordResetToken[]

  @@schema("medcare")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@schema("medcare")
}

model OTPRequest {
  id        String   @id @default(cuid())
  mobile    String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@index([mobile, otp])
  @@schema("medcare")
}

model Medicine {
  id           String     @id @default(cuid())
  name         String
  genericName  String?
  description  String?
  manufacturer String?
  dosageForm   DosageForm @default(TABLET)
  strength     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  patientMedicines PatientMedicine[]

  @@index([name])
  @@schema("medcare")
}

enum DosageForm {
  TABLET
  CAPSULE
  SYRUP
  INJECTION
  CREAM
  DROPS
  INHALER
  OTHER

  @@schema("medcare")
}

model PatientMedicine {
  id         String @id @default(cuid())
  userId     String
  medicineId String

  // Stock Information
  currentStock    Int    @default(0)
  unitType        String @default("tablets")
  dosagePerIntake Float  @default(1)

  // Schedule Information
  frequency     Frequency @default(DAILY)
  timesPerDay   Int       @default(1)
  scheduleTimes String[]
  specificDays  Int[]

  // Alert Settings
  lowStockThreshold     Int     @default(7)
  reminderEnabled       Boolean @default(true)
  stockAlertEnabled     Boolean @default(true)
  reminderMinutesBefore Int     @default(5)

  // Metadata
  startDate DateTime  @default(now())
  endDate   DateTime?
  notes     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicine     Medicine         @relation(fields: [medicineId], references: [id])
  intakes      MedicineIntake[]
  stockHistory StockHistory[]

  @@unique([userId, medicineId])
  @@index([userId])
  @@schema("medcare")
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  AS_NEEDED
  CUSTOM

  @@schema("medcare")
}

model MedicineIntake {
  id                String @id @default(cuid())
  patientMedicineId String
  userId            String

  scheduledTime DateTime
  takenAt       DateTime?
  status        IntakeStatus @default(PENDING)
  dosageTaken   Float?
  notes         String?
  skippedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientMedicine PatientMedicine @relation(fields: [patientMedicineId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledTime])
  @@index([patientMedicineId])
  @@schema("medcare")
}

enum IntakeStatus {
  PENDING
  TAKEN
  SKIPPED
  MISSED

  @@schema("medcare")
}

model StockHistory {
  id                String @id @default(cuid())
  patientMedicineId String

  changeType    StockChangeType
  quantity      Int
  previousStock Int
  newStock      Int
  notes         String?

  createdAt DateTime @default(now())

  patientMedicine PatientMedicine @relation(fields: [patientMedicineId], references: [id], onDelete: Cascade)

  @@index([patientMedicineId])
  @@schema("medcare")
}

enum StockChangeType {
  PURCHASE
  INTAKE
  ADJUSTMENT
  EXPIRED
  LOST

  @@schema("medcare")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("medcare")
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique

  // Email Preferences
  emailEnabled        Boolean @default(true)
  emailForReminders   Boolean @default(true)
  emailForStockAlerts Boolean @default(true)

  // Push Preferences
  pushEnabled        Boolean @default(true)
  pushForReminders   Boolean @default(true)
  pushForStockAlerts Boolean @default(true)

  // Sound Preferences
  soundEnabled Boolean @default(true)

  // Quiet Hours
  quietHoursEnabled Boolean @default(false)
  quietHoursStart   String?
  quietHoursEnd     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("medcare")
}

model Notification {
  id      String              @id @default(cuid())
  userId  String
  type    NotificationType
  channel NotificationChannel
  title   String
  body    String
  data    Json?
  status  NotificationStatus  @default(PENDING)
  sentAt  DateTime?
  readAt  DateTime?
  error   String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([status])
  @@schema("medcare")
}

enum NotificationType {
  MEDICINE_REMINDER
  STOCK_ALERT
  STOCK_OUT
  WELCOME
  SYSTEM

  @@schema("medcare")
}

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP

  @@schema("medcare")
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ

  @@schema("medcare")
}
